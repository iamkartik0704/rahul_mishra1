      "WebFetch(domain:sites.google.com)",
      "WebFetch(domain:www.iitp.ac.in)",
      "Bash(npm install *)",
      "Bash(npm run *)",
      "Bash(curl -s -o /dev/null -w \"HTTP %{http_code}\\\\n\" http://localhost:5174/)",
      "Bash(curl -s http://localhost:5174/src/data/profileData.json)",
