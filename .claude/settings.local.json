      "Read(//tmp/**)",
      "Bash(curl -s -L --max-time 20 \"https://iitp.ac.in/api/api/v1/faculty/93\")",
      "Bash(curl -s -L --max-time 20 \"https://iitp.ac.in/api/api/v1/public/media/45\")",
      "Bash(curl -s -I -L --max-time 20 \"https://iitp.ac.in/api/api/v1/public/media/45\")",
      "Bash(curl -s -o /dev/null -w \"img HTTP %{http_code}\\\\n\" \"http://localhost:5174/img/rahul-mishra.jpg\")"
    ]
  }
